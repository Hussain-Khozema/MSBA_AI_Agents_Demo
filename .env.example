OPENAI_API_KEY=""

# Weather (Open-Meteo - no API key required).
# Waypoints come from the playbook + augmentations; only the timezone is used here.
WEATHER_TZ="America/New_York"


# SMTP delivery (optional - leave REPORT_EMAIL_TO empty to skip)

SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=rxxx@zohomail.com
SMTP_PASSWORD=xxxx
REPORT_EMAIL_TO=


# LangSmith (optional)

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls..........
LANGCHAIN_PROJECT=MSBA_AI_Agents_Demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
